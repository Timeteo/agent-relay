#!/usr/bin/env bash
set -euo pipefail

RELAY_DIR="${AGENT_RELAY_DIR:-$HOME/.agent-relay}"
PID_FILE="$RELAY_DIR/relay-worker.pid"
WORKER_SCRIPT="$RELAY_DIR/bin/relay-worker.py"
LOG_FILE="$RELAY_DIR/logs/relay.log"

usage() {
    echo "Usage: relay-daemon start|stop|restart|status" >&2
    exit 1
}

cmd_start() {
    if [[ -f "$PID_FILE" ]]; then
        PID=$(cat "$PID_FILE")
        if kill -0 "$PID" 2>/dev/null; then
            echo "relay-worker is already running (pid $PID)"
            exit 0
        fi
        rm -f "$PID_FILE"
    fi

    if [[ ! -f "$WORKER_SCRIPT" ]]; then
        echo "Error: worker script not found at $WORKER_SCRIPT" >&2
        echo "Run relay-install first." >&2
        exit 1
    fi

    nohup python3 "$WORKER_SCRIPT" >> "$LOG_FILE" 2>&1 &
    WORKER_PID=$!
    echo "$WORKER_PID" > "$PID_FILE"
    sleep 1

    if kill -0 "$WORKER_PID" 2>/dev/null; then
        echo "relay-worker started (pid $WORKER_PID)"
    else
        echo "Error: relay-worker failed to start — check $LOG_FILE" >&2
        rm -f "$PID_FILE"
        exit 1
    fi
}

cmd_stop() {
    if [[ ! -f "$PID_FILE" ]]; then
        echo "relay-worker is not running (no PID file)"
        return
    fi
    PID=$(cat "$PID_FILE")
    if kill -0 "$PID" 2>/dev/null; then
        kill "$PID"
        rm -f "$PID_FILE"
        echo "relay-worker stopped (pid $PID)"
    else
        echo "relay-worker was not running (stale pid $PID)"
        rm -f "$PID_FILE"
    fi
}

cmd_status() {
    if [[ ! -f "$PID_FILE" ]]; then
        echo "relay-worker: STOPPED"
        return
    fi
    PID=$(cat "$PID_FILE")
    if kill -0 "$PID" 2>/dev/null; then
        echo "relay-worker: RUNNING (pid $PID)"
    else
        echo "relay-worker: STOPPED (stale pid $PID)"
    fi
}

[[ $# -eq 0 ]] && usage

case "$1" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_stop; sleep 1; cmd_start ;;
    status)  cmd_status ;;
    *)       echo "Error: Unknown command: $1" >&2; usage ;;
esac
