#!/usr/bin/env bash
# relay-init: first-time setup of ~/.agent-relay/ (run once)
set -euo pipefail

RELAY_DIR="${AGENT_RELAY_DIR:-$HOME/.agent-relay}"

log() { echo "[relay-init] $*"; }
warn() { echo "[relay-init] WARNING: $*" >&2; }

log "Initializing agent-relay at $RELAY_DIR"

# --- Directories ---
mkdir -p "$RELAY_DIR"/{bin,queue,processing,done,archive,logs}

# --- Default config ---
CONFIG="$RELAY_DIR/config.json"
if [[ ! -f "$CONFIG" ]]; then
    log "Writing default config.json..."
    cat > "$CONFIG" <<'EOF'
{
  "version": "1.0",
  "relay_dir": "~/.agent-relay",
  "default_model": "qwen/qwen3-coder-480b-a35b",
  "fallback_model": "google/gemini-2.0-flash-lite-001",
  "openrouter": {
    "api_key": "$OPENROUTER_API_KEY",
    "base_url": "https://openrouter.ai/api/v1"
  },
  "watcher": {
    "method": "inotify",
    "poll_interval_seconds": 2
  },
  "timeouts": {
    "worker_response_seconds": 120,
    "task_expiry_seconds": 600
  },
  "retry": {
    "max_attempts": 3,
    "backoff_seconds": [2, 5, 15]
  },
  "logging": {
    "level": "info",
    "file": "~/.agent-relay/logs/relay.log"
  }
}
EOF
    chmod 600 "$CONFIG"
else
    log "config.json already exists — skipping"
fi

# --- .env template ---
ENV_FILE="$RELAY_DIR/.env"
if [[ ! -f "$ENV_FILE" ]]; then
    cat > "$ENV_FILE" <<'EOF'
# Copy to ~/.agent-relay/.env and fill in your key
# relay-worker loads this automatically at startup
OPENROUTER_API_KEY=your_key_here
EOF
    chmod 600 "$ENV_FILE"
    log "Wrote .env template"
else
    log ".env already exists — skipping"
fi

# --- Python dependencies ---
log "Installing Python dependencies..."
if command -v pip3 &>/dev/null; then
    pip3 install --quiet requests watchdog
elif command -v pip &>/dev/null; then
    pip install --quiet requests watchdog
else
    warn "pip not found — install manually: pip install requests watchdog"
fi

# --- Validate API key is set ---
if [[ -z "${OPENROUTER_API_KEY:-}" ]]; then
    if grep -q "your_key_here" "$ENV_FILE" 2>/dev/null; then
        warn "OPENROUTER_API_KEY is not set. Edit $ENV_FILE before starting the worker."
    fi
fi

# --- PATH ---
SHELL_RC=""
if [[ "$SHELL" == *"zsh"* ]]; then
    SHELL_RC="$HOME/.zshrc"
elif [[ "$SHELL" == *"bash"* ]]; then
    SHELL_RC="$HOME/.bashrc"
fi

PATH_LINE='export PATH="$HOME/.agent-relay/bin:$PATH"'
if [[ -n "$SHELL_RC" ]] && [[ -f "$SHELL_RC" ]]; then
    if ! grep -q "agent-relay/bin" "$SHELL_RC"; then
        { echo ""; echo "# agent-relay"; echo "$PATH_LINE"; } >> "$SHELL_RC"
        log "Added ~/.agent-relay/bin to PATH in $SHELL_RC"
    fi
fi

# --- Autostart ---
PLATFORM="$(uname -s)"
if [[ "$PLATFORM" == "Darwin" ]]; then
    PLIST_DST="$HOME/Library/LaunchAgents/com.agent-relay.worker.plist"
    PLIST_SRC="$RELAY_DIR/bin/../autostart/com.agent-relay.worker.plist"
    # Try to find autostart dir relative to this script
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
    PLIST_TMPL="$REPO_DIR/autostart/com.agent-relay.worker.plist"

    if [[ ! -f "$PLIST_DST" ]] && [[ -f "$PLIST_TMPL" ]]; then
        log "Installing macOS LaunchAgent..."
        PYTHON_BIN="$(which python3)"
        sed -e "s|~|$HOME|g" -e "s|/usr/bin/python3|$PYTHON_BIN|g" "$PLIST_TMPL" > "$PLIST_DST"
        launchctl load "$PLIST_DST" 2>/dev/null && log "LaunchAgent loaded" \
            || warn "launchctl load failed — run manually or use relay-daemon start"
    fi
elif [[ "$PLATFORM" == "Linux" ]]; then
    SYSTEMD_DIR="$HOME/.config/systemd/user"
    SVC_DST="$SYSTEMD_DIR/agent-relay.service"
    SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
    SVC_TMPL="$REPO_DIR/autostart/agent-relay.service"

    if [[ ! -f "$SVC_DST" ]] && [[ -f "$SVC_TMPL" ]]; then
        log "Installing systemd user service..."
        mkdir -p "$SYSTEMD_DIR"
        sed "s|~|$HOME|g" "$SVC_TMPL" > "$SVC_DST"
        systemctl --user enable --now agent-relay 2>/dev/null && log "systemd service enabled" \
            || warn "systemctl failed — run manually or use relay-daemon start"
    fi
fi

# --- CC hooks ---
CLAUDE_SETTINGS="$HOME/.claude/settings.json"
if [[ -f "$CLAUDE_SETTINGS" ]]; then
    if ! grep -q "relay-status" "$CLAUDE_SETTINGS"; then
        log "Wiring Claude Code hooks..."
        python3 - <<PYEOF
import json

path = "$CLAUDE_SETTINGS"
with open(path) as f:
    settings = json.load(f)

hooks = settings.setdefault("hooks", {})

def ensure_hook(event, command):
    entries = hooks.setdefault(event, [])
    for entry in entries:
        for h in entry.get("hooks", []):
            if h.get("command") == command:
                return
    entries.append({"matcher": "", "hooks": [{"type": "command", "command": command}]})

ensure_hook("PostCompact", "relay-status")
ensure_hook("Startup", "relay-status")

with open(path, "w") as f:
    json.dump(settings, f, indent=2)
print("[relay-init] CC hooks wired")
PYEOF
    else
        log "CC hooks already wired"
    fi
else
    warn "~/.claude/settings.json not found — wire hooks manually after Claude Code setup"
fi

# --- CLAUDE.md ---
CLAUDE_MD="$HOME/.claude/CLAUDE.md"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
APPEND_SRC="$REPO_DIR/claude/CLAUDE.md.append"

if [[ -f "$APPEND_SRC" ]] && [[ -d "$HOME/.claude" ]]; then
    if [[ ! -f "$CLAUDE_MD" ]] || ! grep -q "Agent Relay" "$CLAUDE_MD"; then
        log "Appending relay instructions to CLAUDE.md..."
        echo "" >> "$CLAUDE_MD"
        cat "$APPEND_SRC" >> "$CLAUDE_MD"
    else
        log "CLAUDE.md already has relay instructions"
    fi
fi

# --- Summary ---
echo ""
echo "=== relay-init complete ==="
echo ""
echo "  Config:  $CONFIG"
echo "  API key: edit $ENV_FILE"
echo ""
echo "Next:"
echo "  1. Edit $ENV_FILE — add your OPENROUTER_API_KEY"
echo "  2. relay-daemon start"
echo "  3. relay-status"
if [[ -n "${SHELL_RC:-}" ]]; then
    echo ""
    echo "Reload PATH: source $SHELL_RC"
fi
